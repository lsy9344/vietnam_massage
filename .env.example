# ---------------------------------------------------------------------------
# 로컬 개발 (.env.local 로 복사해서 사용)
# ---------------------------------------------------------------------------
# 로컬 Postgres (Docker) 기준 값. 운영(Neon) 값과 헷갈리지 않게 분리한다.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vietnam_aesthetic"
# 로컬에서는 pooler가 없으므로 DATABASE_URL 과 동일하게 둔다.
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vietnam_aesthetic"

NEXTAUTH_SECRET="replace-with-local-secret"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# 운영 (Vercel + Neon) — 아래 값들은 Vercel 프로젝트의 Environment Variables 에 등록.
# .env 파일로 커밋하지 말 것 (.gitignore 처리됨).
# ---------------------------------------------------------------------------
# DATABASE_URL        : Neon "Pooled connection" 문자열 (런타임 앱이 사용, ?sslmode=require 포함)
#                       예) postgresql://USER:PASS@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
# DIRECT_DATABASE_URL : Neon "Direct connection" 문자열 (prisma migrate deploy 가 사용, pooler 아님)
#                       예) postgresql://USER:PASS@ep-xxxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
# NEXTAUTH_SECRET     : `openssl rand -base64 32` 로 생성한 고유 시크릿 (로컬과 다른 값)
# NEXTAUTH_URL        : 배포 도메인. 예) https://your-app.vercel.app
