generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserAccount {
  id                                         String                              @id @default(cuid())
  email                                      String                              @unique
  accountId                                  String                              @unique @map("account_id")
  passwordHash                               String                              @map("password_hash")
  role                                       String
  employeeId       String?        @unique @map("employee_id")
  employee                                   Employee?                           @relation(fields: [employeeId], references: [id])
  isActive       Boolean    @default(true) @map("is_active")
  lockedUntil                                DateTime?                           @map("locked_until")
  failedLoginCount                           Int                                 @default(0) @map("failed_login_count")
  createdAt                                  DateTime                            @default(now()) @map("created_at")
  updatedAt                                  DateTime                            @updatedAt @map("updated_at")
  loginAttempts                              LoginAttempt[]
  changedServiceCallStatusHistories ServiceCallStatusHistory[]
  confirmedMonthlyClosings MonthlyClosing[]
  changedMigrationVerificationIssueHistories MigrationVerificationIssueHistory[]

  @@map("user_accounts")
}

model Employee {
  id                     String                  @id @default(cuid())
  displayName            String                  @map("display_name")
  staffCode              String                  @unique @map("staff_code")
  employeeGroup          String                  @map("employee_group")
  position               String
  shiftType              String?                 @map("shift_type")
  baseSalary             Int                     @map("base_salary")
  phone                  String?
  birthday               DateTime?               @db.Date
  hireDate               DateTime?               @map("hire_date") @db.Date
  employmentStatus       String                  @default("재직") @map("employment_status")
  sortOrder              Int                     @map("sort_order")
  isActive               Boolean                 @default(true) @map("is_active")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  account                UserAccount?
  therapistRates         TherapistCourseRate[]
  serviceCallAssignments ServiceCallAssignment[]
  handledDailyExpenses   DailyExpense[]
  earcareAttendances     EarcareAttendance[]
  opsAttendances         OpsAttendance[]

  @@unique([employeeGroup, sortOrder], map: "uq_employees_employee_group_sort_order")
  @@map("employees")
}

model LoginAttempt {
  id            String       @id @default(cuid())
  userAccountId String?      @map("user_account_id")
  userAccount   UserAccount? @relation(fields: [userAccountId], references: [id])
  identity      String
  success       Boolean
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("login_attempts")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String   @map("actor_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([targetType, targetId], map: "idx_audit_logs_target_type_target_id")
  @@index([action], map: "idx_audit_logs_action")
  @@map("audit_logs")
}

model MigrationVerificationIssue {
  id                 String                              @id @default(cuid())
  itemKey            String                              @unique @map("item_key")
  kind               String
  sourceSheet        String?                             @map("source_sheet")
  relatedRequirement String?                             @map("related_requirement")
  relatedStory       String?                             @map("related_story")
  status             String
  assigneeName       String?                             @map("assignee_name")
  note               String?                             @db.VarChar(500)
  createdAt          DateTime                            @default(now()) @map("created_at")
  updatedAt          DateTime                            @updatedAt @map("updated_at")
  histories          MigrationVerificationIssueHistory[]

  @@index([kind, status], map: "idx_migration_verification_issues_kind_status")
  @@index([sourceSheet], map: "idx_migration_verification_issues_source_sheet")
  @@map("migration_verification_issues")
}

model MigrationVerificationIssueHistory {
  id                 String                     @id @default(cuid())
  issueId            String                     @map("issue_id")
  issue              MigrationVerificationIssue @relation(fields: [issueId], references: [id])
  previousStatus     String?                    @map("previous_status")
  newStatus          String                     @map("new_status")
  note               String?                    @db.VarChar(500)
  changedByAccountId String                     @map("changed_by_account_id")
  changedByAccount   UserAccount                @relation(fields: [changedByAccountId], references: [id])
  changedAt          DateTime                   @default(now()) @map("changed_at")
  createdAt          DateTime                   @default(now()) @map("created_at")

  @@index([issueId, changedAt], map: "idx_migration_verification_histories_issue_changed")
  @@index([changedByAccountId, changedAt], map: "idx_migration_verification_histories_actor_changed")
  @@map("migration_verification_issue_histories")
}

model OperatingMonth {
  id                 String              @id @default(cuid())
  monthKey           String              @unique @map("month_key")
  startDate          DateTime            @map("start_date") @db.Date
  endDate            DateTime            @map("end_date") @db.Date
  status             String              @default("작성중")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  serviceCalls       ServiceCall[]
  dailyExpenses      DailyExpense[]
  earcareAttendances EarcareAttendance[]
  opsAttendances     OpsAttendance[]
  monthlyClosings MonthlyClosing[]

  @@map("operating_months")
}

model MonthlyClosing {
  id                   String         @id @default(cuid())
  operatingMonthId     String         @map("operating_month_id")
  operatingMonth       OperatingMonth @relation(fields: [operatingMonthId], references: [id])
  closeVersion         Int            @default(1) @map("close_version")
  snapshotJson         Json           @map("snapshot_json")
  confirmedByAccountId String         @map("confirmed_by_account_id")
  confirmedByAccount   UserAccount    @relation(fields: [confirmedByAccountId], references: [id])
  confirmedAt          DateTime       @map("confirmed_at")
  reopenedAt           DateTime?      @map("reopened_at")
  reopenedByAccountId  String?        @map("reopened_by_account_id")
  reopenReason         String?        @map("reopen_reason")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@unique([operatingMonthId, closeVersion], map: "uq_monthly_closings_month_version")
  @@index([operatingMonthId, closeVersion], map: "idx_monthly_closings_month_version")
  @@index([confirmedAt], map: "idx_monthly_closings_confirmed_at")
  @@index([confirmedByAccountId, confirmedAt], map: "idx_monthly_closings_confirmer_confirmed_at")
  @@map("monthly_closings")
}

model Room {
  id                     String        @id @default(cuid())
  displayName            String        @map("display_name")
  migrationReferenceName String        @map("migration_reference_name")
  sortOrder              Int           @unique @map("sort_order")
  isActive               Boolean       @default(true) @map("is_active")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  serviceCalls           ServiceCall[]

  @@map("rooms")
}

model CodeItem {
  id              String   @id @default(cuid())
  codeType        String   @map("code_type")
  code            String
  displayName     String   @map("display_name")
  sortOrder       Int      @map("sort_order")
  isSystemDefault Boolean  @default(false) @map("is_system_default")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([codeType, code], map: "uq_code_items_code_type_code")
  @@unique([codeType, sortOrder], map: "uq_code_items_code_type_sort_order")
  @@map("code_items")
}

model TimeSlot {
  id        String   @id @default(cuid())
  value     String   @unique
  sortOrder Int      @unique @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("time_slots")
}

model Course {
  id             String                @id @default(cuid())
  code           String                @unique
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  policies       CoursePolicy[]
  therapistRates TherapistCourseRate[]
  serviceCalls   ServiceCall[]

  @@map("courses")
}

model ServiceCall {
  id                String                     @id @default(cuid())
  operatingMonthId  String                     @map("operating_month_id")
  operatingMonth    OperatingMonth             @relation(fields: [operatingMonthId], references: [id])
  serviceDate       DateTime                   @map("service_date") @db.Date
  startTime         String                     @map("start_time")
  roomId            String                     @map("room_id")
  room              Room                       @relation(fields: [roomId], references: [id])
  courseId          String                     @map("course_id")
  course            Course                     @relation(fields: [courseId], references: [id])
  customerMemo      String?                    @map("customer_memo")
  status            String
  discountTypeCode  String?                    @map("discount_type_code")
  paymentMethodCode String?                    @map("payment_method_code")
  note              String?
  confirmationCode  String?                    @map("confirmation_code")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")
  assignments       ServiceCallAssignment[]
  statusHistories   ServiceCallStatusHistory[]

  @@index([operatingMonthId, serviceDate], map: "idx_service_calls_month_date")
  @@index([roomId, serviceDate], map: "idx_service_calls_room_date")
  @@index([status, serviceDate], map: "idx_service_calls_status_date")
  @@map("service_calls")
}

model ServiceCallAssignment {
  id             String      @id @default(cuid())
  serviceCallId  String      @map("service_call_id")
  serviceCall    ServiceCall @relation(fields: [serviceCallId], references: [id])
  employeeId     String      @map("employee_id")
  employee       Employee    @relation(fields: [employeeId], references: [id])
  assignmentRole String      @map("assignment_role")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@unique([serviceCallId, assignmentRole], map: "uq_service_call_assignments_call_role")
  @@index([employeeId, assignmentRole], map: "idx_service_call_assignments_employee_role")
  @@map("service_call_assignments")
}

model ServiceCallStatusHistory {
  id                 String      @id @default(cuid())
  serviceCallId      String      @map("service_call_id")
  serviceCall        ServiceCall @relation(fields: [serviceCallId], references: [id])
  previousStatus     String      @map("previous_status")
  newStatus          String      @map("new_status")
  changedByAccountId String      @map("changed_by_account_id")
  changedByAccount   UserAccount @relation(fields: [changedByAccountId], references: [id])
  changedAt          DateTime    @default(now()) @map("changed_at")
  createdAt          DateTime    @default(now()) @map("created_at")

  @@index([serviceCallId, changedAt], map: "idx_service_call_status_histories_call_changed_at")
  @@index([changedByAccountId, changedAt], map: "idx_service_call_status_histories_actor_changed_at")
  @@map("service_call_status_histories")
}

model DailyExpense {
  id                  String         @id @default(cuid())
  operatingMonthId    String         @map("operating_month_id")
  operatingMonth      OperatingMonth @relation(fields: [operatingMonthId], references: [id])
  expenseDate         DateTime       @map("expense_date") @db.Date
  amount              Int
  description         String
  handledByEmployeeId String         @map("handled_by_employee_id")
  handledByEmployee   Employee       @relation(fields: [handledByEmployeeId], references: [id])
  note                String?
  isActive            Boolean        @default(true) @map("is_active")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@index([operatingMonthId, expenseDate], map: "idx_daily_expenses_month_date")
  @@index([handledByEmployeeId, expenseDate], map: "idx_daily_expenses_handler_date")
  @@map("daily_expenses")
}

model EarcareAttendance {
  id               String         @id @default(cuid())
  operatingMonthId String         @map("operating_month_id")
  operatingMonth   OperatingMonth @relation(fields: [operatingMonthId], references: [id])
  attendanceDate    DateTime       @map("attendance_date") @db.Date
  employeeId        String         @map("employee_id")
  employee         Employee       @relation(fields: [employeeId], references: [id])
  statusCode        String         @map("status_code")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([operatingMonthId, attendanceDate, employeeId], map: "uq_earcare_attendances_month_date_employee")
  @@index([employeeId, attendanceDate], map: "idx_earcare_attendances_employee_date")
  @@map("earcare_attendances")
}

model OpsAttendance {
  id               String         @id @default(cuid())
  operatingMonthId String         @map("operating_month_id")
  operatingMonth   OperatingMonth @relation(fields: [operatingMonthId], references: [id])
  attendanceDate   DateTime       @map("attendance_date") @db.Date
  employeeId       String         @map("employee_id")
  employee         Employee       @relation(fields: [employeeId], references: [id])
  statusCode       String         @map("status_code")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([operatingMonthId, attendanceDate, employeeId], map: "uq_ops_attendances_month_date_employee")
  @@index([employeeId, attendanceDate], map: "idx_ops_attendances_employee_date")
  @@map("ops_attendances")
}

model CoursePolicy {
  id                      String   @id @default(cuid())
  courseId                String   @map("course_id")
  course                  Course   @relation(fields: [courseId], references: [id])
  name                    String
  durationMinutes         Int      @map("duration_minutes")
  basePrice               Int      @map("base_price")
  opsCallCredit           Int      @map("ops_call_credit")
  earcarePoolAmount       Int      @map("earcare_pool_amount")
  requiresSecondTherapist Boolean  @default(false) @map("requires_second_therapist")
  tvDisplayName           String   @map("tv_display_name")
  effectiveFromMonth      String   @map("effective_from_month")
  effectiveToMonth        String?  @map("effective_to_month")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([courseId, effectiveFromMonth], map: "idx_course_policies_course_month")
  @@map("course_policies")
}

model TherapistCourseRate {
  id                 String   @id @default(cuid())
  therapistId        String   @map("therapist_id")
  therapist          Employee @relation(fields: [therapistId], references: [id])
  courseId           String   @map("course_id")
  course             Course   @relation(fields: [courseId], references: [id])
  amount             Int
  effectiveFromMonth String   @map("effective_from_month")
  effectiveToMonth   String?  @map("effective_to_month")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([therapistId, courseId, effectiveFromMonth], map: "idx_therapist_course_rates_lookup")
  @@map("therapist_course_rates")
}

model OpsDailyIncentiveRule {
  id                 String   @id @default(cuid())
  thresholdCallCount Int      @map("threshold_call_count")
  personalAmount     Int      @map("personal_amount")
  effectiveFromMonth String   @map("effective_from_month")
  effectiveToMonth   String?  @map("effective_to_month")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([thresholdCallCount, effectiveFromMonth], map: "idx_ops_daily_incentive_rules_lookup")
  @@map("ops_daily_incentive_rules")
}

model OpsMonthlyIncentiveRule {
  id                 String   @id @default(cuid())
  thresholdCallCount Int      @map("threshold_call_count")
  totalAmount        Int      @map("total_amount")
  leadShare          Float    @map("lead_share")
  counterTeamShare   Float    @map("counter_team_share")
  waiterTeamShare    Float    @map("waiter_team_share")
  effectiveFromMonth String   @map("effective_from_month")
  effectiveToMonth   String?  @map("effective_to_month")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([thresholdCallCount, effectiveFromMonth], map: "idx_ops_monthly_incentive_rules_lookup")
  @@map("ops_monthly_incentive_rules")
}
