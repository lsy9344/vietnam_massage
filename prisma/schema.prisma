generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserAccount {
  id               String         @id @default(cuid())
  email            String         @unique
  accountId        String         @unique @map("account_id")
  passwordHash     String         @map("password_hash")
  role             String
  employeeId       String?        @unique @map("employee_id")
  employee         Employee?      @relation(fields: [employeeId], references: [id])
  isActive         Boolean        @default(true) @map("is_active")
  lockedUntil      DateTime?      @map("locked_until")
  failedLoginCount Int            @default(0) @map("failed_login_count")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  loginAttempts    LoginAttempt[]

  @@map("user_accounts")
}

model Employee {
  id          String       @id @default(cuid())
  displayName String       @map("display_name")
  staffCode   String       @unique @map("staff_code")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  account     UserAccount?

  @@map("employees")
}

model LoginAttempt {
  id            String       @id @default(cuid())
  userAccountId String?      @map("user_account_id")
  userAccount   UserAccount? @relation(fields: [userAccountId], references: [id])
  identity      String
  success       Boolean
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("login_attempts")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String   @map("actor_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([targetType, targetId], map: "idx_audit_logs_target_type_target_id")
  @@index([action], map: "idx_audit_logs_action")
  @@map("audit_logs")
}

model OperatingMonth {
  id        String   @id @default(cuid())
  monthKey  String   @unique @map("month_key")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  status    String   @default("작성중")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("operating_months")
}

model Room {
  id                     String   @id @default(cuid())
  displayName            String   @map("display_name")
  migrationReferenceName String   @map("migration_reference_name")
  sortOrder              Int      @unique @map("sort_order")
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("rooms")
}
